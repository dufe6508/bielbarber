# ─── Banco de dados (Supabase / Postgres) ───────────────────────────────────
# Pooled (runtime) e direct (migrations). Pegue no painel do Supabase.
DATABASE_URL="postgresql://...:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://...:5432/postgres"

# ─── Supabase (Auth/Storage) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."

# ─── Admin (barbeiro) ───────────────────────────────────────────────────────
# Senha inicial (antes da 1ª troca pela UI) e segredo de assinatura da sessão.
ADMIN_PASSWORD="defina-a-senha-do-barbeiro"
ADMIN_SESSION_SECRET="troque-por-uma-string-aleatoria-longa"

# ─── Push notifications (Web Push / VAPID) ──────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@bielbarber.com"

# ─── Mercado Pago (cobrança de mensalidade) ─────────────────────────────────
# Preencha para LIGAR a integração — sem isto o app cai no fluxo manual
# (barbeiro confirma o pagamento na mão). Nenhuma mudança de código é necessária.
MERCADOPAGO_ACCESS_TOKEN=""
NEXT_PUBLIC_MP_PUBLIC_KEY=""
# Segredo de assinatura do webhook (painel MP > Webhooks > "Assinatura secreta").
# Vazio = não valida x-signature (ok p/ testes); preencha antes do go-live.
# Muda junto com a conta/URL do barbeiro.
MP_WEBHOOK_SECRET=""

# ─── Google Calendar (sync automático de agendamentos p/ o admin) ──────────
# Painel Google Cloud > APIs & Services > Credentials > OAuth 2.0 Client ID.
# GOOGLE_CALENDAR_REDIRECT_URI deve ser IDÊNTICO (byte a byte) a uma URI
# cadastrada em "Authorized redirect URIs" no Google Cloud Console, senão
# a tela de consentimento do Google falha com "Error 400: redirect_uri_mismatch"
# antes mesmo do app receber o callback. Formato:
# https://<dominio-de-producao>/api/admin/google-calendar/callback
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REDIRECT_URI="https://bielbarber.vercel.app/api/admin/google-calendar/callback"
GOOGLE_CALENDAR_ID="primary"

# ─── App ────────────────────────────────────────────────────────────────────
# Base pública usada em back_urls e notification_url do Mercado Pago.
NEXT_PUBLIC_APP_URL="https://bielbarber.vercel.app"

# ─── Cron (cobrança automática diária) ──────────────────────────────────────
# A Vercel envia "Authorization: Bearer <CRON_SECRET>" para /api/cron/cobrancas.
CRON_SECRET=""
